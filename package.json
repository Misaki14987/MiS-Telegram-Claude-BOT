{
  "name": "telegram-claude-bot",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "build": "rm -rf dist build && tsc && ncc build dist/src/index.js -o build --source-map && cp -r dist/plugins build/plugins && rm -rf dist",
    "dev": "tsx src/index.ts",
    "start": "PLUGINS_DIR=./build/plugins node build/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "dotenv": "^16.4.7",
    "node-telegram-bot-api": "^0.66.0"
  },
  "devDependencies": {
    "@types/node-telegram-bot-api": "^0.64.7",
    "@vercel/ncc": "^0.38.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
