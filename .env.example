TELEGRAM_BOT_TOKEN=your_bot_token_here

# Comma-separated Telegram user IDs allowed to use the bot (empty = allow all)
ALLOWED_USER_IDS=

# Directory where Claude Code will operate
WORK_DIR=/home/misa

# Claude model (opus, sonnet, haiku)
CLAUDE_MODEL=sonnet

# Path to claude executable
# CLAUDE_PATH=/usr/local/bin/claude

# Chat ID to receive bot startup/crash notifications (get it from /start in your bot)
NOTIFY_CHAT_ID=

# ── X Monitor Plugin ─────────────────────────────────────────────────────────
# X (Twitter) API v2 Bearer Token — https://developer.x.com/en/portal/dashboard
X_BEARER_TOKEN=

# Polling interval in milliseconds (default: 900000 = 15 minutes)
# Note: X API Free tier allows ~1 request per 15 min; Basic tier allows more.
X_POLL_INTERVAL_MS=900000
